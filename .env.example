# =============================================
# REQUIRED — Database
# =============================================
# JawsDB MySQL connection URL (provided by Heroku addon)
JAWSDB_URL=mysql://user:password@host:3306/database

# =============================================
# REQUIRED — Authentication (Magic Link SSO)
# =============================================
# Magic Link publishable key (from https://dashboard.magic.link)
MAGIC_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXX

# Magic Link secret key
MAGIC_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXX

# Cookie domain for cross-subdomain SSO
# Use .aubreydemo.com for production (note the leading dot)
COOKIE_DOMAIN=.aubreydemo.com

# =============================================
# REQUIRED — AI (Gemini Proxy)
# =============================================
# Google Gemini API key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Gemini model (optional, defaults to gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# =============================================
# OPTIONAL — Admin
# =============================================
# Comma-separated list of admin email addresses
ADMIN_EMAILS=you@example.com,admin@example.com

# =============================================
# OPTIONAL — Server
# =============================================
# Port (Heroku sets this automatically)
# PORT=3000
