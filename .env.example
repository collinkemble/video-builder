# ─── Server ───
PORT=3000

# ─── Database (Heroku JawsDB provides this automatically) ───
JAWSDB_URL=mysql://user:pass@host:3306/dbname

# ─── Authentication (Magic Link SSO) ───
JWT_SECRET=your-jwt-secret-here
COOKIE_DOMAIN=.aubreydemo.com
ADMIN_EMAILS=admin@example.com

# ─── Gemini AI (Script Generation + B-Roll) ───
GEMINI_API_KEY=your-gemini-api-key

# ─── ElevenLabs (Voiceover TTS) ───
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ─── Cloudflare R2 (Video Storage) ───
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=video-builder
R2_PUBLIC_URL=https://your-r2-public-url.com

# ─── PocketSIC (Scene Import) ───
POCKETSIC_BASE_URL=https://pocketsic.aubreydemo.com

# ─── Encryption (for storing API keys) ───
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=your-64-char-hex-key
